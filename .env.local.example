# =============================================================================
# JONBEATZ.DEV site — environment template
# Copy to .env.local (gitignored — NEVER commit). Fill only what this project needs.
#
# INCLUDED here: OmniVoice (JARVIS), project MCPs (21st-dev, browserbase, composio),
# Mem0 (scope jonbeatz_dev), Hostinger deploy.
# NOT here (personal JonBeatz profile only): DeepSeek/LiteLLM, Telegram, ComfyUI,
# image generation, Google Workspace.
# =============================================================================

# -----------------------------------------------------------------------------
# Site variant (optional). This project defaults to the RED jonbeatz.dev build.
# Set to "default" ONLY if you ever want the legacy gold jon-beatz.com theme.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_JB_VARIANT=dev

# -----------------------------------------------------------------------------
# LM Studio + Mem0 — site memory, scoped to jonbeatz_dev (NOT jonbeatz_personal).
# Non-secret config. Shares the LM Studio server on :1234 with Hermes (no swap).
# -----------------------------------------------------------------------------
LMSTUDIO_HOST=127.0.0.1
LMSTUDIO_PORT=1234
HERMES_LM_MODEL=qwen3-4b-instruct-2507
HERMES_LM_CONTEXT=81920
HERMES_LM_PARALLEL=2
# Mem0 scope — hard-separated from the personal profile. Keep the jonbeatz_dev values.
JBD_MEM0_USER=jonbeatz_dev
JBD_MEM0_COLLECTION=jonbeatz_dev_memories
JBD_MEM0_QDRANT_DIR=qdrant_jonbeatz_dev

# -----------------------------------------------------------------------------
# OmniVoice (JARVIS) — shared Hermes install; all optional (defaults work).
# Voice is RITUAL-ONLY (see .cursor/rules/voice-policy.mdc).
# -----------------------------------------------------------------------------
# JARVIS_VOICE_POLICY=ritual          # ritual | off
# JARVIS_VOICE_ERRORS=1               # speak critical errors (1) or not (0)
# OMNIVOICE_PYTHON=D:\Hermes\apps\OmniVoice\.venv\Scripts\python.exe
# JARVIS_OMNI_PORT=18776

# -----------------------------------------------------------------------------
# Project MCP keys (synced into .cursor/mcp.json via: npm run sync:mcp-env)
# .cursor/mcp.json is gitignored — keys never reach the public repo.
# -----------------------------------------------------------------------------
# 21ST_DEV_MAGIC_API_KEY=
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# COMPOSIO_API_KEY=

# Global MCP keys (synced into ~/.cursor/mcp.json — shared across all projects)
# GITHUB_PERSONAL_ACCESS_TOKEN=
# TAVILY_API_KEY=
# FAL_API_KEY=

# -----------------------------------------------------------------------------
# Project backup (npm run backup / backup:quick)
# Separate root from the personal JonBeatz profile — guarded in the backup script.
# -----------------------------------------------------------------------------
JBD_BACKUP_ROOT=G:\Hermes_Project_BackUpz\JonBeatz.dev

# -----------------------------------------------------------------------------
# Hostinger (static deploy to jonbeatz.dev) — uses the Hostinger MCP / Hostinger-Ops skill.
# See .cursor/docs/HOSTINGER-REFERENCE.md + .cursor/docs/JONBEATZ-DEV-DEPLOY.md.
# -----------------------------------------------------------------------------
# API token (hPanel -> Account -> API). Synced to the global hostinger-* MCP quartet
# via: npm run sync:mcp-env  (account token — shared with the personal profile MCP).
# HOSTINGER_API_TOKEN=

# Account-wide SSH (optional — for `npm run site:ssh -- "<cmd>"`). ONE login reaches
# every site on the account; only the folder path differs. hPanel -> Advanced -> SSH Access.
# HOSTINGER_SSH_HOST=
# HOSTINGER_SSH_PORT=65002
# HOSTINGER_SSH_USER=
# HOSTINGER_SSH_PASSWORD=
