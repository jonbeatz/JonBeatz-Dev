# =============================================================================
# JONBEATZ.DEV site — environment template
# Copy to .env.local (gitignored — NEVER commit). Fill only what this project needs.
#
# DESIGN PRINCIPLE: this standalone site does NOT inherit JonBeatz personal
# secrets. Personal services (JARVIS voice, Telegram, DeepSeek/LiteLLM, ComfyUI,
# image gen) belong to the JonBeatz personal profile and are intentionally absent.
# =============================================================================

# -----------------------------------------------------------------------------
# Site variant (optional). This project defaults to the RED jonbeatz.dev build.
# Set to "default" ONLY if you ever want the legacy gold jon-beatz.com theme.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_JB_VARIANT=dev

# -----------------------------------------------------------------------------
# LM Studio + Mem0 — site memory, scoped to jonbeatz_dev (NOT jonbeatz_personal).
# Non-secret config. Shares the LM Studio server on :1234 with Hermes (no swap).
# -----------------------------------------------------------------------------
LMSTUDIO_HOST=127.0.0.1
LMSTUDIO_PORT=1234
HERMES_LM_MODEL=qwen3-4b-instruct-2507
HERMES_LM_CONTEXT=81920
HERMES_LM_PARALLEL=2
# Mem0 scope — hard-separated from the personal profile. Keep the jonbeatz_dev values.
JBD_MEM0_USER=jonbeatz_dev
JBD_MEM0_COLLECTION=jonbeatz_dev_memories
JBD_MEM0_QDRANT_DIR=qdrant_jonbeatz_dev

# -----------------------------------------------------------------------------
# Project backup (npm run backup / backup:quick)
# Separate root from the personal JonBeatz profile — guarded in the backup script.
# -----------------------------------------------------------------------------
JBD_BACKUP_ROOT=G:\Hermes_Project_BackUpz\JonBeatz.dev

# -----------------------------------------------------------------------------
# Hostinger (static deploy to jonbeatz.dev) — uses the Hostinger MCP / Hostinger-Ops skill.
# Get a token at hPanel -> API. Account token, not a JonBeatz personal secret.
# -----------------------------------------------------------------------------
# HOSTINGER_API_TOKEN=
